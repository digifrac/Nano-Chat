# Runtime files written per install - never commit anything under data/
# except the .htaccess that protects the folder. (No trailing # comments on
# pattern lines: git treats them as part of the pattern.)
data/*
!data/.htaccess

# Per-site bootstrap - written by install.php; holds the absolute path to the
# outside-webroot config dir. Per-install, never committed.
/bootstrap.php

